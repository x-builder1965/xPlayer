{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Electron: Main",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron.cmd"
      },
      "args": [
        ".",                          // カレントディレクトリのアプリを起動
        // "D:/（試作中）/JavaApp/xPlayerテストデータ/沈黙の艦隊/沈黙の艦隊 - シーズン１【東京湾大海戦】/沈黙の艦隊 - シーズン１【東京湾大海戦】 第02話 「シーバット浮上」.mp4",
        "--remote-debugging-port=9223" // Rendererアタッチ用ポート（必須）
      ],
      "console": "integratedTerminal",
      "outputCapture": "std",
      "timeout": 30000
    },
    {
      "name": "Debug Electron: Renderer",
      "type": "chrome",
      "request": "attach",
      "port": 9223,
      "webRoot": "${workspaceFolder}",     // または "${workspaceFolder}/src" などRendererのルートに
      "timeout": 60000,                    // 起動遅延対策で長めに
      "sourceMaps": true,
      "trace": true                        // 接続エラー時に便利
    }
  ],
  "compounds": [
    {
      "name": "Debug Electron: All",
      "configurations": [
        "Debug Electron: Main",
        "Debug Electron: Renderer"
      ]
    }
  ]
}